{
  "expo": {
    "name": "Doctor-App",
    "slug": "Doctor-App-Dev2",
    "version": "1.0.2",
    "orientation": "portrait",
    "icon": "./assets/icon.jpg",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash.jpg",
      "resizeMode": "contain",
      "backgroundColor": "#122827"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#122827",
        "foregroundImage": "./assets/icon.jpg"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.ashinnn.DoctorAppDev2"
    },
    "web": {
      "favicon": "./assets/icon.jpg"
    },
    "newArchEnabled": false,
    "plugins": [
      "expo-secure-store",
      "expo-image-picker",
      "expo-asset",
      "expo-font"
    ],
    "extra": {
      "eas": {
        "projectId": "15a90d27-850a-446a-aa95-328cd0a1af54"
      }
    }
  }
}
